export default function App() {
  const [screen, setScreen] = useState("home"); // home | swipe | results
  const [household, setHousehold] = useState([{ id: 1, name: "Dad", role: "Head", emoji: "👨", joined: true }]);
  const [inviteName, setInviteName] = useState("");
  const [likes, setLikes] = useState([]);
  const [matched, setMatched] = useState(null);
  const [coords, setCoords] = useState(null);
  const [restaurants, setRestaurants] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);

  const invite = () => {
    if (!inviteName.trim()) return;
    const emojis = ["👩", "🧒", "👧", "👦", "👵", "👴", "🧑"];
    setHousehold((h) => [...h, {
      id: Date.now(), name: inviteName.trim(), role: "Member",
      emoji: emojis[h.length % emojis.length], joined: Math.random() > 0.4,
    }]);
    setInviteName("");
  };

  // When swiping ends, pick the top-liked cuisine and load restaurants.
  const finishSwiping = async (liked) => {
    setLikes(liked);
    const top = liked[0] || CUISINES[0];
    setMatched(top);
    setScreen("results");
    await loadRestaurants(top.id);
  };

  const loadRestaurants = async (cuisineId) => {
    // No backend configured -> use mock data so the app still works.
    if (!API_BASE) {
      setRestaurants(MOCK[cuisineId] || []);
      return;
    }
    setLoading(true);
    setError(null);
    try {
      let where = coords;
      if (!where) {
        try {
          where = await getCurrentLocation(); // GPS prompt
          setCoords(where);
        } catch {
          throw new Error("location-denied");
        }
      }
      const { restaurants: list } = await findRestaurants({
        cuisine: cuisineId, lat: where.lat, lng: where.lng,
        radiusMeters: 8000, openNow: true,
      });
      setRestaurants(list);
    } catch (e) {
      setError(e.message === "location-denied" ? "location" : "fetch");
      setRestaurants(MOCK[cuisineId] || []); // graceful fallback
    } finally {
      setLoading(false);
    }
  };

  return (
    <div style={S.app}>
      <FontAndAnim />
      <Header screen={screen} onHome={() => setScreen("home")} />
      {!API_BASE && screen === "home" && (
        <div style={S.demoBanner}>Demo mode · add VITE_API_BASE to use live restaurants</div>
      )}
      {screen === "home" && (
        <Home household={household} inviteName={inviteName} setInviteName={setInviteName}
          invite={invite} start={() => setScreen("swipe")} />
      )}
      {screen === "swipe" && <Swipe onDone={finishSwiping} />}
      {screen === "results" && (
        <Results matched={matched} likes={likes} restaurants={restaurants}
          loading={loading} error={error} onBack={() => setScreen("home")} />
      )}
    </div>
  );
}

function Header({ screen, onHome }) {
