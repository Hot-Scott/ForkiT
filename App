    <header style={S.header}>
      <button onClick={onHome} style={S.logo}>
        <span style={{ color: P.accent }}>Fork</span><span style={{ color: P.gold }}>It</span>
      </button>
      <span style={S.tagline}>
        {screen === "home" && "the household table"}
        {screen === "swipe" && "swipe your cravings"}
        {screen === "results" && "tonight's match"}
      </span>
    </header>
  );
}

function Home({ household, inviteName, setInviteName, invite, start }) {
  const head = household.find((m) => m.role === "Head");
  const joined = household.filter((m) => m.joined).length;
  return (
    <main style={S.main}>
      <div className="fadeup" style={S.hero}>
        <h1 style={S.h1}>Who's eating tonight?</h1>
        <p style={S.sub}>{head?.name} is the head of the household. Invite the family, then everyone
          swipes to find a craving you all agree on.</p>
      </div>
      <section className="fadeup" style={{ ...S.panel, animationDelay: "0.06s" }}>
        <div style={S.panelHead}>
          <span style={S.panelTitle}>The Household</span>
          <span style={S.badge}>{joined}/{household.length} ready</span>
        </div>
        <div style={S.memberGrid}>
          {household.map((m) => (
            <div key={m.id} style={S.member}>
              <div style={S.avatar}>{m.emoji}</div>
              <div style={S.mName}>{m.name}</div>
              <div style={m.role === "Head" ? S.headTag : S.memberTag}>
                {m.role === "Head" ? "👑 Head" : m.joined ? "Ready" : "Invited…"}
              </div>
            </div>
          ))}
        </div>
        <div style={S.inviteRow}>
          <input value={inviteName} onChange={(e) => setInviteName(e.target.value)}
            onKeyDown={(e) => e.key === "Enter" && invite()}
            placeholder="Add a family member's name" style={S.input} />
          <button onClick={invite} style={S.inviteBtn}>+ Invite</button>
        </div>
      </section>
      <button onClick={start} className="pulse" style={S.cta}>Start Swiping →</button>
      <p style={S.footnote}>Only the head can start the round · everyone votes</p>
    </main>
  );
}

function Swipe({ onDone }) {
  const [idx, setIdx] = useState(0);
  const [liked, setLiked] = useState([]);
  const [drag, setDrag] = useState({ x: 0, active: false });
  const [flash, setFlash] = useState(null);
  const start = useRef(0);
  const deck = CUISINES;
  const card = deck[idx];

  const decide = (yes) => {
    setFlash(yes ? "yes" : "no");
    const next = yes ? [...liked, card] : liked;
    setLiked(next);
    setTimeout(() => {
      setFlash(null);
      setDrag({ x: 0, active: false });
      if (idx + 1 >= deck.length) onDone(next);
      else setIdx((i) => i + 1);
    }, 260);
  };

  const down = (x) => { start.current = x; setDrag({ x: 0, active: true }); };
  const move = (x) => { if (drag.active) setDrag((d) => ({ ...d, x: x - start.current })); };
  const up = () => {
    if (!drag.active) return;
    if (drag.x > 110) decide(true);
    else if (drag.x < -110) decide(false);
    else setDrag({ x: 0, active: false });
  };

  if (!card) return null;
  const rot = drag.x / 18;
  const yesOp = Math.max(0, Math.min(1, drag.x / 110));
  const noOp = Math.max(0, Math.min(1, -drag.x / 110));

  return (
    <main style={S.main}>
      <div style={S.progress}>
        {deck.map((_, i) => <span key={i} style={{ ...S.dot, background: i <= idx ? P.accent : "#33293c" }} />)}
      </div>
      <div style={S.deck}>
        {deck[idx + 1] && (
          <div style={{ ...S.swipeCard, transform: "scale(0.94) translateY(14px)", filter: "brightness(0.7)", zIndex: 1 }}>
            <CardFace c={deck[idx + 1]} />
          </div>
        )}
        <div style={{
          ...S.swipeCard, zIndex: 2,
          transform: flash ? `translateX(${flash === "yes" ? 520 : -520}px) rotate(${flash === "yes" ? 22 : -22}deg)`
            : `translateX(${drag.x}px) rotate(${rot}deg)`,
          transition: drag.active ? "none" : "transform 0.35s cubic-bezier(.2,.8,.2,1)",
          cursor: drag.active ? "grabbing" : "grab",
        }}
          onMouseDown={(e) => down(e.clientX)} onMouseMove={(e) => move(e.clientX)}
          onMouseUp={up} onMouseLeave={up}
          onTouchStart={(e) => down(e.touches[0].clientX)} onTouchMove={(e) => move(e.touches[0].clientX)} onTouchEnd={up}>
          <div style={{ ...S.stamp, ...S.stampYes, opacity: yesOp }}>YUM</div>
          <div style={{ ...S.stamp, ...S.stampNo, opacity: noOp }}>NAH</div>
          <CardFace c={card} />
        </div>
      </div>
      <div style={S.swipeBtns}>
        <button onClick={() => decide(false)} style={{ ...S.circle, ...S.circleNo }}>✕</button>
        <button onClick={() => decide(true)} style={{ ...S.circle, ...S.circleYes }}>♥</button>
      </div>
      <p style={S.footnote}>Drag the card or tap · left = no, right = yes</p>
    </main>
  );
}

function CardFace({ c }) {
  return (
    <div style={{ ...S.cardInner, background: `linear-gradient(150deg, ${c.c1}, ${c.c2})` }}>
      <div style={S.cardGrain} />
      <div style={S.cardEmoji}>{c.emoji}</div>
      <div style={S.cardName}>{c.name}</div>
      <div style={S.cardBlurb}>{c.blurb}</div>
    </div>
  );
}

function Results({ matched, likes, restaurants, loading, error, onBack }) {
  return (
    <main style={S.main}>
      <div className="fadeup" style={S.matchHero}>
        <div style={S.matchBadge}>IT'S A MATCH</div>
        <div style={S.matchEmoji}>{matched?.emoji}</div>
        <h1 style={S.h1}>{matched?.name} it is</h1>
        <p style={S.sub}>
          {loading ? "Finding spots near you…"
            : error === "location" ? "Couldn't get your location — showing sample spots."
            : error === "fetch" ? "Couldn't reach the restaurant service — showing sample spots."
            : `${matched?.name} spots near your household, by distance.`}
        </p>
      </div>
      <section style={S.restoList}>
        {loading && <div style={S.loadingCard}>Loading…</div>}
        {!loading && restaurants.map((r, i) => (
          <div key={r.id || r.name} className="fadeup" style={{ ...S.resto, animationDelay: `${i * 0.07}s` }}>
            <div style={S.resoThumb}>
              {r.photoName ? <img alt="" src={photoUrl(r.photoName, 120)} style={S.resoImg} /> : matched?.emoji}
            </div>
            <div style={{ flex: 1 }}>
              <div style={S.resoName}>{r.name}</div>
              <div style={S.resoTag}>{r.tag}</div>
              <div style={S.resoMeta}>
                {r.rating != null && <span style={{ color: P.gold }}>★ {r.rating}</span>}
                {r.distanceMiles != null && <span>· {r.distanceMiles} mi</span>}
                {r.price && <span>· {r.price}</span>}
                {r.openNow === true && <span style={{ color: "#3FB86C" }}>· Open</span>}
              </div>
            </div>
            <button style={S.resoGo}>Go →</button>
          </div>
        ))}
      </section>
      {likes.length > 1 && (
        <p style={S.alsoLiked}>Also liked: {likes.slice(1).map((l) => l.name).join(", ")}</p>
      )}
      <button onClick={onBack} style={S.secondary}>↺ New Round</button>
    </main>
  );
}

function FontAndAnim() {
